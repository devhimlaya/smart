// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TEACHER
  ADMIN
  REGISTRAR
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum GradeLevel {
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_10
}

enum SubjectType {
  CORE           // 30% WW, 50% PT, 20% QA (English, Math, Science, Filipino, AP)
  PE_HEALTH      // 20% WW, 60% PT, 20% QA
  MAPEH          // Computed as average of Music, Arts, PE, Health
  TLE            // 20% WW, 60% PT, 20% QA
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      Role
  firstName String?
  lastName  String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher?
}

model Teacher {
  id               String            @id @default(cuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId       String            @unique
  specialization   String?
  classAssignments ClassAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Student {
  id           String       @id @default(cuid())
  lrn          String       @unique // Learner Reference Number
  firstName    String
  middleName   String?
  lastName     String
  suffix       String?      // Jr., III, etc.
  birthDate    DateTime?
  gender       String?
  address      String?
  guardianName String?
  guardianContact String?
  enrollments  Enrollment[]
  grades       Grade[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Section {
  id          String       @id @default(cuid())
  name        String       // e.g., "Einstein", "Newton"
  gradeLevel  GradeLevel
  schoolYear  String       // e.g., "2025-2026"
  adviser     String?      // Teacher name or ID
  enrollments Enrollment[]
  classAssignments ClassAssignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, gradeLevel, schoolYear])
}

model Subject {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String            // e.g., "English", "Mathematics", "Science"
  description      String?
  type             SubjectType       @default(CORE)
  writtenWorkWeight Int              @default(30)  // percentage
  perfTaskWeight   Int               @default(50)  // percentage
  quarterlyAssessWeight Int          @default(20)  // percentage
  classAssignments ClassAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ClassAssignment {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schoolYear String   // e.g., "2025-2026"
  grades     Grade[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([teacherId, subjectId, sectionId, schoolYear])
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schoolYear String   // e.g., "2025-2026"
  status     String   @default("ENROLLED") // ENROLLED, TRANSFERRED, DROPPED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, sectionId, schoolYear])
}

model Grade {
  id                String          @id @default(cuid())
  studentId         String
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classAssignmentId String
  classAssignment   ClassAssignment @relation(fields: [classAssignmentId], references: [id], onDelete: Cascade)
  quarter           Quarter

  // Written Work scores (multiple activities)
  writtenWorkScores Json?    // Array of { name: string, score: number, maxScore: number }
  
  // Performance Task scores (multiple activities)
  perfTaskScores    Json?    // Array of { name: string, score: number, maxScore: number }
  
  // Quarterly Assessment (usually one exam)
  quarterlyAssessScore Float?
  quarterlyAssessMax   Float?  @default(100)

  // Computed grades (stored for performance)
  writtenWorkPS     Float?   // Percentage Score
  perfTaskPS        Float?   // Percentage Score
  quarterlyAssessPS Float?   // Percentage Score
  initialGrade      Float?   // Sum of weighted scores
  quarterlyGrade    Float?   // Transmuted grade

  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, classAssignmentId, quarter])
}
